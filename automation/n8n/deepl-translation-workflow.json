      "parameters": {
        "jsCode": "// Also translate title and excerpt\nconst titleTR = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api-free.deepl.com/v2/translate',\n  headers: {\n    'Authorization': `DeepL-Auth-Key ${this.getEnvVariable('DEEPL_API_KEY')}`\n  },\n  body: new URLSearchParams({\n    'auth_key': this.getEnvVariable('DEEPL_API_KEY'),\n    'text': this.getNode('webhook_trigger').json.title,\n    'target_lang': 'TR',\n    'source_lang': 'EN'\n  })\n});\n\nreturn {\n  tr: {\n    title: titleTR?.translations?.[0]?.text || '',\n    excerpt: $('translate_to_turkish').json.excerpt || '',\n    content: $('translate_to_turkish').json.translations?.[0]?.text || ''\n  },\n  fr: {\n    title: '',\n    excerpt: '',\n    content: $('translate_to_french').json.translations?.[0]?.text || ''\n  },\n  de: {\n    title: '',\n    excerpt: '',\n    content: $('translate_to_german').json.translations?.[0]?.text || ''\n  },\n  ru: {\n    title: '',\n    excerpt: '',\n    content: $('translate_to_russian').json.translations?.[0]?.text || ''\n  }\n};"
