    {
      "parameters": {
        "jsCode": "// Clean HTML content for translation\nfunction cleanHTML(html) {\n  if (!html) return '';\n  \n  // Remove script and style tags\n  html = html.replace(/<script\\b[^<]*(?:(?!<\\/script>)<[^<]*)*<\\/script>/gi, '');\n  html = html.replace(/<style\\b[^<]*(?:(?!<\\/style>)<[^<]*)*<\\/style>/gi, '');\n  \n  // Remove HTML comments\n  html = html.replace(/<!--.*?-->/gs, '');\n  \n  // Remove event handlers\n  html = html.replace(/\\s*(onclick|onload|onerror|onmouseover)\\s*=\\s*\"[^\"]*\"/gi, '');\n  \n  // Remove class, id, style attributes\n  html = html.replace(/\\s*class\\s*=\\s*\"[^\"]*\"/gi, '');\n  html = html.replace(/\\s*id\\s*=\\s*\"[^\"]*\"/gi, '');\n  html = html.replace(/\\s*style\\s*=\\s*\"[^\"]*\"/gi, '');\n  \n  // Convert div to p\n  html = html.replace(/<div\\b[^>]*>/gi, '<p>');\n  html = html.replace(/<\\/div>/gi, '</p>');\n  \n  // Remove span tags but keep content\n  html = html.replace(/<span\\b[^>]*>/gi, '');\n  html = html.replace(/<\\/span>/gi, '');\n  \n  // Remove empty tags\n  html = html.replace(/<p>\\s*<\\/p>/gi, '');\n  html = html.replace(/<h[2-4]>\\s*<\\/h[2-4]>/gi, '');\n  \n  // Collapse multiple whitespace\n  html = html.replace(/\\s{2,}/g, ' ');\n  \n  return html.trim();\n}\n\nreturn {\n  post_id: $json.post_id,\n  title: $json.title,\n  excerpt: $json.excerpt || '',\n  content: cleanHTML($json.content),\n  slug: $json.slug,\n  post_type: $json.post_type,\n  timestamp: new Date().toISOString()\n};"
      },
      "id": "clean_html",
      "name": "Clean HTML Content",
